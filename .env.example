# ─── Database ────────────────────────────────────────────────────────────────
# Local dev (SQLite — zero setup)
DATABASE_URL="file:./dev.db"

# Production (PostgreSQL — Supabase / Neon both have free tiers)
# 1. Change prisma/schema.prisma  →  provider = "postgresql"
# 2. Run: npx prisma migrate deploy
# DATABASE_URL="postgresql://user:password@host:5432/ekcup?schema=public"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Required in production — must match your deployed URL exactly
NEXTAUTH_URL="http://localhost:3000"

# Generate a secret:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-real-secret"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# 1. Go to https://console.developers.google.com
# 2. Create a project → Enable "Google+ API" → OAuth 2.0 Client IDs
# 3. Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Email magic links (optional) ─────────────────────────────────────────────
# Requires an SMTP server.  Example using Gmail app password:
# EMAIL_SERVER="smtp://you@gmail.com:app-password@smtp.gmail.com:587"
# EMAIL_FROM="Ek Cup <no-reply@ekcup.in>"
EMAIL_SERVER=""
EMAIL_FROM=""

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# 1. Sign up at https://dashboard.razorpay.com
# 2. Settings → API Keys → Generate Test Key
# 3. Settings → Webhooks → Add URL: https://yourdomain.com/api/payment/webhook
#    Select events: payment.captured, payment.failed
#    Copy the webhook secret below
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ─── Email notifications (optional) ──────────────────────────────────────────
# Sign up at https://resend.com  (free tier: 3,000 emails/month)
# Without this, notifications are logged to console only
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Ek Cup <notifications@ekcup.in>"

# ─── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ══════════════════════════════════════════════════════════════════════════════
# SCALABILITY — all free tier, all optional (app works without them in dev)
# ══════════════════════════════════════════════════════════════════════════════

# ─── Prisma Accelerate (connection pooling + edge cache) ──────────────────────
# Replaces DATABASE_URL when set. Prevents connection-pool exhaustion on
# serverless platforms (Vercel, Railway). Free tier at https://pris.ly/accelerate
# 1. Create a project → paste your Postgres URL → copy the Accelerate URL
# 2. Replace DATABASE_URL above with the prisma:// URL below
# DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=<your-key>"

# ─── Upstash Redis (distributed rate limiting) ────────────────────────────────
# Without this, rate limits use an in-memory Map — broken on multi-instance deploys.
# Free tier: 10,000 requests/day at https://upstash.com (no credit card)
# 1. Create a Redis database → copy REST URL and token
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Cloudflare R2 (avatar storage) ──────────────────────────────────────────
# Without this, avatars are saved to public/avatars/ on disk — lost on redeploy.
# Free tier: 10 GB storage, zero egress cost at https://dash.cloudflare.com → R2
# 1. Create bucket (e.g. "ekcup-avatars")
# 2. Settings → Public access → Allow
# 3. Manage R2 API Tokens → Create token (Object Read & Write)
# 4. Copy your Account ID from the R2 dashboard overview
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME="ekcup-avatars"
# Public URL: R2 bucket URL → Settings → Public bucket URL
CLOUDFLARE_R2_PUBLIC_URL=""
