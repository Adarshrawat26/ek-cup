generator client {
  provider = "prisma-client-js"
}

enum TransactionStatus {
  pending
  paid
  failed
}

enum Audience {
  public
  members
}

// ── Database ──────────────────────────────────────────────────────────────────
// Production: Neon PostgreSQL (free tier, Singapore region)
//
// Two URLs are needed:
//   DATABASE_URL  → pooler URL  (used by the app at runtime, handles concurrency)
//   DIRECT_URL    → direct URL  (used by Prisma CLI for migrations only)
//
// To get both from Neon:
//   Dashboard → your project → Connection string → toggle "Pooled" on/off
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  creators      Creator[]   @relation("CreatorOwner")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Creator {
  id              String       @id @default(cuid())
  userId          String?      @unique
  username        String       @unique
  name            String
  bio             String?
  avatarUrl       String?
  tags            String       @default("")
  instagramUrl    String?
  youtubeUrl      String?
  twitterUrl      String?
  totalEarned     Int          @default(0)
  totalSupporters Int          @default(0)
  user            User?        @relation("CreatorOwner", fields: [userId], references: [id], onDelete: Cascade)
  supports        Support[]
  memberships     Membership[]
  posts           CreatorPost[]
  shopItems       ShopItem[]
  transactions    Transaction[]
  onboardingComplete Boolean   @default(false)
  payout           CreatorPayout?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model CreatorPayout {
  id              String   @id @default(cuid())
  creatorId       String   @unique
  creator         Creator  @relation(fields: [creatorId], references: [id])
  upiId           String?
  accountHolder   String?
  accountNumber   String?
  ifsc            String?
  bankName        String?
  createdAt       DateTime @default(now())
}

model Support {
  id               String   @id @default(cuid())
  creatorId        String
  creator          Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  supporterName    String?
  message          String?
  amount           Int
  cups             Int      @default(1)
  createdAt        DateTime @default(now())

  @@index([creatorId, createdAt(sort: Desc)])
}

model Transaction {
  id                String   @id @default(cuid())
  creatorId         String
  creator           Creator  @relation(fields: [creatorId], references: [id])
  razorpayOrderId   String   @unique
  razorpayPaymentId String?
  amount            Int
  status            TransactionStatus @default(pending)
  createdAt         DateTime @default(now())

  @@index([creatorId, createdAt(sort: Desc)])
}

model Membership {
  id           String   @id @default(cuid())
  creatorId    String
  name         String
  priceInPaise Int
  perks        String
  creator      Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([creatorId])
}

model CreatorPost {
  id         String   @id @default(cuid())
  creatorId  String
  creator    Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title      String
  body       String
  audience   Audience @default(public)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([creatorId, createdAt(sort: Desc)])
}

model ShopItem {
  id           String   @id @default(cuid())
  creatorId    String
  creator      Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  name         String
  description  String
  priceInPaise Int
  deliveryUrl  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([creatorId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Platform config ───────────────────────────────────────────────────────────
// Key-value store for admin-controlled settings.
// Changes take effect on the next request — no redeploy needed.
//
// Keys in use:
//   platform_fee_percent  — integer 0-100 (default: 0)
//   maintenance_mode      — "true" | "false"
model PlatformConfig {
  key       String   @id          // e.g. "platform_fee_percent"
  value     String                // always stored as string, parsed at read time
  updatedAt DateTime @updatedAt
  updatedBy String?               // admin email who last changed it
}